",\"category\":\"Category\",\"orders\":\"Orders\",\"details\":\"Details\",\"customers\":\"Customers\",\"manageReviews\":\"Manage Reviews\",\"referrals\":\"Referrals\",\"settings\":\"Settings\",\"myCourses\":\"My Courses\",\"courseDetails\":\"Course Details\",\"fleet\":\"Fleet\",\"email\":\"Email\",\"chat\":\"Chat\",\"calendar\":\"Calendar\",\"kanban\":\"Kanban\",\"invoice\":\"Invoice\",\"preview\":\"Preview\",\"edit\":\"Edit\",\"user\":\"User\",\"view\":\"View\",\"rolesPermissions\":\"Roles \u0026 Permissions\",\"roles\":\"Roles\",\"permissions\":\"Permissions\",\"pages\":\"Pages\",\"userProfile\":\"User Profile\",\"accountSettings\":\"Account Settings\",\"faq\":\"FAQ\",\"miscellaneous\":\"Miscellaneous\",\"comingSoon\":\"Coming Soon\",\"underMaintenance\":\"Under Maintenance\",\"pageNotFound404\":\"Page Not Found - 404\",\"notAuthorized401\":\"Not Authorized - 401\",\"authPages\":\"Auth Pages\",\"login\":\"Login\",\"loginV1\":\"Login v1\",\"loginV2\":\"Login v2\",\"register\":\"Register\",\"registerV1\":\"Register v1\",\"registerV2\":\"Register v2\",\"registerMultiSteps\":\"Register Multi-Steps\",\"verifyEmail\":\"Verify Email\",\"verifyEmailV1\":\"Verify Email v1\",\"verifyEmailV2\":\"Verify Email v2\",\"forgotPassword\":\"Forgot Password\",\"forgotPasswordV1\":\"Forgot Password v1\",\"forgotPasswordV2\":\"Forgot Password v2\",\"resetPassword\":\"Reset Password\",\"resetPasswordV1\":\"Reset Password v1\",\"resetPasswordV2\":\"Reset Password v2\",\"twoSteps\":\"Two Steps\",\"twoStepsV1\":\"Two Steps v1\",\"twoStepsV2\":\"Two Steps v2\",\"wizardExamples\":\"Wizard Examples\",\"propertyListing\":\"Property Listing\",\"createDeal\":\"Create Deal\",\"dialogExamples\":\"Dialog Examples\",\"widgetExamples\":\"Widget Examples\",\"basic\":\"Basic\",\"advanced\":\"Advanced\",\"statistics\":\"Statistics\",\"gamification\":\"Gamification\",\"actions\":\"Actions\",\"formsAndTables\":\"Forms \u0026 Tables\",\"formLayouts\":\"Form Layouts\",\"formValidation\":\"Form Validation\",\"formWizard\":\"Form Wizard\",\"reactTable\":\"React Table\",\"formELements\":\"Form Elements\",\"muiTables\":\"MUI Tables\",\"chartsMisc\":\"Charts \u0026 Misc\",\"charts\":\"Charts\",\"recharts\":\"Recharts\",\"apex\":\"Apex\",\"foundation\":\"Foundation\",\"components\":\"Components\",\"menuExamples\":\"Menu Examples\",\"raiseSupport\":\"Raise Support\",\"documentation\":\"Documentation\",\"others\":\"Others\",\"itemWithBadge\":\"Item with Badge\",\"externalLink\":\"External Link\",\"menuLevels\":\"Menu Levels\",\"menuLevel2\":\"Menu Level 2\",\"menuLevel3\":\"Menu Level 3\",\"disabledMenu\":\"Disabled Menu\",\"support_module\":\"Support\",\"sale_agent\":\"Sales Agent\"}},\"children\":\"$L20\"}]}]}]}]}]\n"])</script><script>self.__next_f.push([1,"20:[\"$\",\"$L21\",null,{\"systemMode\":\"light\",\"children\":\"$L22\"}]\n"])</script><script>self.__next_f.push([1,"5:[\"$\",\"$L1b\",null,{\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$L1d\",null,{\"settingsCookie\":{},\"mode\":\"light\",\"children\":[\"$\",\"$L1e\",null,{\"direction\":\"$undefined\",\"systemMode\":\"light\",\"children\":[\"$\",\"$L1f\",null,{\"locale\":\"assets\",\"dictionary\":{\"navigation\":\"$1a:props:children:props:children:props:children:props:children:props:dictionary:navigation\",\"landing\":{\"hero\":{\"animated\":{\"prefix\":\"The Future of Ecommerce Automation Management\",\"words\":{\"marketplace\":\"Marketplace\",\"warehouse\":\"Warehouse\",\"salesChannel\":\"Sales Channel\"}},\"tagline1\":\"One platform that connects every marketplace, automates your operations, and drives growth with accuracy.\",\"tagline2\":\"Turn complexity into control with ExactFlow, your complete eCommerce automation software. From ecommerce order management software to intelligent AI agents for ecommerce, we help you reduce e-commerce errors and scale with ease.\",\"form\":{\"emailPlaceholder\":\"Enter Your Email\",\"getStarted\":\"Get Started\",\"getStartedAria\":\"Get Started\",\"emailRequired\":\"Email is required.\",\"emailInvalid\":\"Please enter a valid email address.\",\"welcomeFailed\":\"Failed to send welcome email.\"},\"dashboardAlt\":\"ExactFlow dashboard preview\"},\"marquee\":{\"connectWith\":\"Connect with\",\"integrations\":\"1300+ powerful integrations\",\"effortlessly\":\"effortlessly.\"},\"features\":{\"heading\":\"The Future of eCommerce Management is ExactFlow\",\"subtext\":\"ExactFlow is your all-in-one ecommerce management system, designed to unify every operation using ecommerce AI solutions. It saves time, reduces errors, and provides you with full control over your online business.\",\"and\":\", and\",\"agentsMissionLine\":\"are not just add-ons; they are the backbone of the workforce in your organization. All of them are dedicated to a mission:\"},\"enterprise\":{\"heading\":\"Built to Your 2x Growth\",\"subtext\":\"Grow with enterprise-level security, smart workflows, and full control. ExactFlow’s ecommerce management system with multi-channel inventory management software adapts to your business and keeps performance strong using ecommerce automation.\",\"contactLink\":\"Contact us\",\"today\":\"today.\",\"features\":{\"brandVoice\":{\"title\":\"Bespoke Brand Voice\",\"description\":\"Every message strengthens your brand\"},\"teamWorkflows\":{\"title\":\"Team Workflows\",\"description\":\"Faster teams with higher output\"},\"privacy\":{\"title\":\"Data Privacy \u0026 Security\",\"description\":\"Your data stays untouchable \u0026 secure\"},\"access\":{\"title\":\"Granular Access Control\",\"description\":\"Full control, zero risk\"}}},\"agents\":{\"heading\":\"AI Agents - Future of Your Operations\",\"subtext\":\"ExactFlow offers businesses a team of AI agents designed to eliminate inefficiency, reduce errors, and help them grow consistently through ecommerce automation tools. All of them are professionals, which reinforces the most significant aspects of your ecommerce operations.\",\"fallbackRole\":\"AI Agent\",\"slides\":[{\"title\":\"AI Support Assistant for eCommerce\",\"description\":\"Axel improves customer service as our AI chatbot for ecommerce. He responds immediately, operates on all channels, and ensures loyalty by providing customers with prompt, dependable, and precise support 24/7.\"},{\"title\":\"AI Sales Assistant for eCommerce\",\"description\":\"Zane helps turn data into sales results. He identifies new opportunities, researches industry competition, and develops sales strategies that advance revenue through precision with ecommerce agents.\"},{\"title\":\"AI Purchase Assistant for eCommerce\",\"description\":\"Tesa simplifies procurement and makes it controlled. She links inventory with real demand, prevents expensive errors, and maintains your supply chain stable, efficient, and profitable using multichannel inventory management.\"},{\"title\":\"AI Financial Assistant for eCommerce\",\"description\":\"Raya pays attention to finance. She monitors costs, predicts profitability, and points out risks so that you can be sure about the correct financial decision.\"},{\"title\":\"AI Operational Assistant for eCommerce\",\"description\":\"Keep your team on track with Kai. From task management to productivity insights, it ensures efficient operations across the board.\"},{\"title\":\"AI HR Assistant for eCommerce\",\"description\":\"She manages payroll, recruiting, and compliance to keep your teams organized, supported, and dedicated towards growth.\"}]},\"blog\":{\"headingPrefix\":\"Latest Insights and\",\"headingEmphasis\":\"Industry Updates\",\"by\":\"By\",\"seeMore\":\"See More Blogs\"},\"faq\":{\"heading\":\"Frequently Asked Questions\",\"subtext\":\"Find quick answers to common questions about our AI agents, plans, and features. These details will help you see how ExactFlow supports your business with automation and reliability.\",\"items\":[{\"q\":\"Can ExactFlow integrate with my existing marketplaces and tools?\",\"a\":\"Yes, our marketplace integration tool connects smoothly with platforms like Amazon, Shopify, eBay, and more, so you can manage everything in one place with ecommerce automation tools.\"},{\"q\":\"How do ExactFlow agents reduce errors in operations?\",\"a\":\"Each agent is designed for accuracy. For example, our AI purchasing agent syncs stock with real-time demand, while our AI financial assistant ensures numbers are always precise using e-commerce AI solutions.\"},{\"q\":\"Is ExactFlow suitable for fast scaling AI eCommerce platforms?\",\"a\":\"Absolutely. Our ecommerce management system is built for growth. It helps you automate ecommerce operations, streamline workflows, and scale without adding extra overhead with AI in ecommerce.\"},{\"q\":\"How secure is my business data with ExactFlow?\",\"a\":\"We use enterprise-level security, encryption, and strict compliance standards to protect sensitive business and customer information at every stage.\"},{\"q\":\"Do I need a large team to use ExactFlow?\",\"aPrefix\":\"No, ExactFlow replaces repetitive manual work with automation. Even small teams can operate like large enterprises with the help of our AI agents for ecommerce. Learn more\",\"aboutUsLink\":\"about us\"}]},\"contact\":{\"heading\":\"Contact Us\",\"title\":\"Let's work together\",\"subtext\":\"Any question or remark? Just write us a message\",\"form\":{\"heading\":\"Share your ideas\",\"fullName\":\"Full name\",\"email\":\"Personal email address\",\"phone\":\"Phone number\",\"message\":\"Message\",\"send\":\"Send Inquiry\",\"sendAria\":\"Send Inquiry\",\"sent\":\"✓ Sent Successfully\",\"workEmail\":\"Work email address\"},\"validation\":{\"nameRequired\":\"Name is required\",\"nameMin\":\"Name must be at least 2 characters long\",\"emailRequired\":\"Email is required\",\"emailInvalid\":\"Please enter a valid email address\",\"phoneRequired\":\"Phone number is required\",\"phoneInvalid\":\"Please enter a valid phone number\",\"messageRequired\":\"Message is required\",\"messageMin\":\"Message must be at least 2 characters long\"}}},\"common\":\"$1a:props:children:props:children:props:children:props:children:props:dictionary:common\",\"pricing\":{\"hero\":{\"heading\":\"The Best AI Automation Plan for Every E-commerce Business\",\"description\":\"Whether you're growing your Shopify store or running multiple online shops and marketplaces, ExactFlow offers flexible e-commerce AI subscription pricing that helps you scale with confidence. Our online business smart tools manage the day-to-day activities, sales, finances, and customer service using AI agents for e-commerce business services, so your team can focus on planning rather than doing manual tasks. We've designed multiple plans to match every stage of growth, whether you need smart Shopify tools, AI agents, or a fully custom AI automation plan.\",\"ctaDemo\":\"GET A DEMO\",\"ctaTrial\":\"START A FREE TRIAL\",\"imageAlt\":\"Professional woman using tablet\"},\"usageSlider\":{\"minLabel\":\"0 orders\",\"maxLabel\":\"15,000 orders\",\"title\":\"Estimate your monthly orders\",\"subtitle\":\"Adjust the slider to calculate your Regular plan price\",\"ordersUnit\":\"orders\",\"caption\":\"{{base}} base + {{perOrder}} × {{orders}} orders\"},\"trusted\":{\"heading\":\"Trusted By Growing Brands Worldwide\"},\"simple\":{\"heading\":\"Simple, Transparent Pricing\",\"subtext\":\"Choose the plan that fits your business needs. Scale as you grow.\"},\"plans\":{\"mostPopular\":\"Most Popular\",\"freeLabel\":\"Free\",\"perMonth\":\"/month\",\"freeCaption\":\"Get started with the free plan\",\"billedMonthly\":\"Billed monthly. Annual billing available.\",\"free\":{\"title\":\"Free\",\"description\":\"Perfect for getting started and testing\",\"buttonText\":\"Start Free\",\"features\":{\"0\":\"Up to 500 active products\",\"1\":\"Up to 100 orders per month\",\"2\":\"Basic integrations\",\"3\":\"AI features\",\"4\":\"Priority support\"}},\"regular\":{\"title\":\"Regular\",\"description\":\"For growing businesses with higher volume\",\"buttonText\":\"Get Started\",\"features\":{\"0\":\"Unlimited active products\",\"1\":\"Unlimited orders\",\"2\":\"All integrations included\",\"3\":\"Email support\",\"4\":\"AI features\"}},\"enterprise\":{\"title\":\"Enterprise\",\"description\":\"Custom solutions for large-scale operations\",\"buttonText\":\"Contact Sales\",\"features\":{\"0\":\"10,000+ orders per month\",\"1\":\"Unlimited products\",\"2\":\"All standard integrations\",\"3\":\"Custom integrations\",\"4\":\"Dedicated account manager\",\"5\":\"Priority support\"}},\"starter\":{\"title\":\"Starter\",\"description\":\"Target: Early-stage \u0026 small Shopify merchants\",\"buttonText\":\"GET STARTED\",\"features\":{\"0\":\"1 marketplace region\",\"1\":\"Up to 1,000 marketplace orders/month\",\"2\":\"Up to 1,000 active SKU matches\",\"3\":\"Standard sync speed\",\"4\":\"Email support\"}},\"growth\":{\"title\":\"Growth\",\"description\":\"Target: Scaling Shopify brands\",\"buttonText\":\"GET A DEMO\",\"features\":{\"0\":\"Up to 2 marketplace regions\",\"1\":\"Up to 5,000 marketplace orders/month\",\"2\":\"Up to 5,000 active SKU matches\",\"3\":\"Priority sync queue\",\"4\":\"Priority support\"}},\"pro\":{\"title\":\"Pro\",\"description\":\"Target: High-volume sellers \u0026 agencies\",\"buttonText\":\"GET A DEMO\",\"features\":{\"0\":\"Up to 4 marketplace regions\",\"1\":\"Up to 20,000 marketplace orders/month\",\"2\":\"Up to 20,000 active SKU matches\",\"3\":\"Faster sync frequency\",\"4\":\"Advanced logs \u0026 diagnostics\",\"5\":\"Dedicated onboarding\"}}},\"freePlanNotice\":{\"title\":\"Free Plan Notice:\",\"body\":\"When you reach 100 orders in a month, your account will be temporarily disabled until you upgrade to a paid plan or the next month begins (which resets your order limit). Exceeding the product limit does not disable your account.\"},\"help\":{\"heading\":\"Questions about pricing?\",\"subtext\":\"Our team is here to help you choose the right plan for your business\"},\"why\":{\"title\":\"Why Are We the Right Choice for Your Business?\",\"p1Prefix\":\"We understand that it can be difficult to scale an e-commerce business when all processes seem detached, and your team is stuck doing repetitive work. This is where\",\"p1Suffix\":\"comes in with AI automation.\",\"p2Prefix\":\"Whether you're managing a Shopify store, using our Shopify app, or running multiple online shops and marketplaces, we bring you a single platform that gives your team and business order, speed, and clarity, so your operations finally run the way they should. Learn more\",\"aboutUsLink\":\"about us.\"},\"flow\":{\"heading\":\"The Future of Growth Runs on Flow\",\"bodyPrefix\":\"Every hour lost to repetitive work slows your momentum. With AI automation, ExactFlow simplifies the details, minimizes costly slip-ups, and gives your team the power to focus on long-term growth.\",\"today\":\"today.\",\"cta\":\"BOOK YOUR DEMO TODAY\"},\"faq\":{\"heading\":\"Got Questions? We’ve Got Straight Answers.\",\"items\":[{\"q\":\"Do AI agents bill separately?\",\"a\":\"No. Each plan includes a set number of AI agents for e-commerce business based on the tier: Starter (1 agent), Growth (multiple agents), and Enterprise (all agents), with transparent AI agents cost.\"},{\"q\":\"Can I switch plans anytime?\",\"a\":\"Yes. You can upgrade or downgrade your plan anytime as your business grows.\"},{\"q\":\"Do you offer custom pricing for large companies?\",\"a\":\"Yes. The Enterprise plan is fully customizable based on your AI automation, Shopify app usage, and integration needs through our custom AI automation plan.\"},{\"q\":\"Does it include Shopify and marketplace integrations in the pricing?\",\"a\":\"Yes. Limits of integration increase via plan.\"},{\"q\":\"Is there any setup fee?\",\"a\":\"No. All plans include free setup and onboarding.\"},{\"q\":\"What payment options are available?\",\"a\":\"ExactFlow has monthly and annual billing that do not have long-term contracts.\"},{\"q\":\"Does it have a demo before purchase?\",\"a\":\"Yes. You can book a demo anytime to explore the platform and Shopify app features before subscribing.\"}]}},\"about\":{\"meta\":{\"title\":\"About ExactFlow | Ecommerce Automation Team\",\"description\":\"Discover how ExactFlow uses AI agents for ecommerce, workflow automation, and digital teammates to reduce errors and scale growth.\"},\"hero\":{\"heading\":\"TURN BUSINESS CHAOS INTO CONTROL\",\"description\":\"ExactFlow transforms disjointed processes into seamless control with AI assistants handling HR, finance, procurement, and support with perfect accuracy and eliminating errors and wasted time, so the outcome is a business that runs leaner, faster, and smarter by freeing your team to pursue aggressive growth and long-term success through e-commerce automation.\",\"ctaDemo\":\"GET A DEMO\"},\"story\":{\"heading\":\"Our Story\",\"p1\":\"was designed with a clear objective: to enable eCommerce brands to cope with the daily suffering of operating numerous marketplaces. We saw the amount of time wasted by teams on manual updates, stock errors, and redundant support work, and how workflow automation could free up that time. The same time could have been used to create better brands, to add more products, and to target more buyers.\",\"p2\":\"So we created a system that acts as an additional pair of hands to every brand. Having smart agents, marketplace integration, and automation, ExactFlow ensures that the work process proceeds seamlessly and growth is constant, as digital teammates that eCommerce teams may count on. We continue to enhance our tools today with one promise to make e-commerce easier, smarter, and scale-ready for everyone.\",\"signature\":\"— Muhammad Ibraheem, Founder of ExactFlow\",\"imageAlt\":\"ExactFlow Team\"},\"mission\":{\"heading\":\"Mission\",\"body\":\"Our mission is to provide eCommerce brands with intelligent automation and eliminate mistakes, lower the workload, and scale any business confidently and delegate routine tasks to AI agents so that a team may grow, innovate, and build lasting customer trust using AI agents for eCommerce and eCommerce automation.\",\"imageAlt\":\"ExactFlow Mission\"},\"vision\":{\"heading\":\"Vision\",\"body\":\"Our vision is to attain a future in which running an eCommerce brand might be as natural as people and AI agents operating together, each performing their respective roles optimally, creating a partnership that makes faster decisions, executes more effectively, and achieves consistent, sustainable growth for any business through workflow automation.\",\"imageAlt\":\"ExactFlow Vision\"},\"numbers\":{\"heading\":\"The Power of ExactFlow in Numbers\",\"subtext\":\"Our platform provides the scale and flexibility that today's businesses require through seamless order management to an integrated, hybrid workforce.\",\"stats\":{\"0\":{\"label\":\"businesses supported\"},\"1\":{\"label\":\"countries with a global presence\"},\"2\":{\"label\":\"orders processed yearly\"},\"3\":{\"label\":\"focus on making eCommerce smarter\"}}},\"timeline\":{\"heading\":\"From Idea To Reality\",\"subtext\":\"A journey of building digital teammates that eCommerce businesses can use to transform how companies run.\",\"punctuation\":{\"comma\":\",\"},\"links\":{\"hr\":\"HR\",\"finance\":\"finance\",\"procurement\":\"procurement\",\"support\":\"support\",\"and\":\"and\"},\"steps\":{\"0\":{\"label\":\"2023 - The Beginning\",\"description\":\"We could see how the HR, finance, procurement, and support struggled, and based on those issues, the concept of digital teammates, with our initial working models beginning to emerge.\"},\"1\":{\"label\":\"2024 - Building the Agents\",\"description\":\"We created departmental agents and cooperated with early adopters to make them sharper, faster, more efficient, and reliable, which saved businesses precious hours per week and prevented costly pitfalls.\"},\"2\":{\"label\":\"2025 - The Launch\",\"descriptionPrefix\":\"ExactFlow was transformed into a complete set of agents, and the companies could connect\",\"descriptionSuffix\":\"into a single connected flow being driven by teammates who operate 24/7.\"},\"3\":{\"label\":\"Looking Ahead\",\"description\":\"We are pushing to even smarteren our agents so that we can reach more industries and bring to the future a business where growing concerns will not be a heavy burden.\"}}},\"why\":{\"heading\":\"Why Choose Us\",\"p1\":\"The future of eCommerce lies with the brands that are fast-paced and error-free. ExactFlow makes this future real through the introduction of smart AI agents and convenient marketplace integration. Each agent has major but time-consuming jobs like HR, finance, purchasing and customer service so that your team will work on what is important.\",\"p2Prefix\":\"At the same time, our platform brings together all the marketplaces under a single system, and confusion becomes clarity. The result is an eCommerce business that runs smoothly, grows with flexibility, and stays ahead of the competition through e-commerce automation and AI agents for eCommerce.\",\"contactUs\":\"Contact us\",\"today\":\"today.\"},\"agents\":{\"heading\":\"AI Agents and Marketplace Integrations for Ecommerce Brands\",\"p1\":\"Managing an eCommerce brand is a stressful business, through working long hours, continuous errors, and endless tasks. This is not the case anymore since ExactFlow will present intelligent agents that will become reliable work partners to you. They deal with more daily routine tasks so your team can work on building, creating, and increasing growth through workflow automation.\",\"p2\":\"The mere differences are what make us special: we do not just provide one more tool; we give true peace of mind. We transform pressure into clarity by integrating HR, finance, procurement, and support into a single smooth flow with digital teammates that eCommerce teams can be confident in. And with ExactFlow, you will use less time to solve the problem and more time to work on bigger objectives.\"},\"cta\":{\"heading\":\"Transform Your Business – Get a Free Demo Today\",\"p1\":\"More tools do not make your business grow. It grows with teammates that eliminate mistakes, save time and allow you to scale with confidence using AI agents for e-commerce and ecommerce automation.\",\"p2\":\"So don’t wait and meet them at ExactFlow.\",\"button\":\"GET A DEMO\"},\"faq\":{\"heading\":\"Frequently Asked Questions\",\"items\":[{\"q\":\"What is ExactFlow in simple terms?\",\"a\":\"ExactFlow is a set of agents that handle HR, finance, procurement, and support. They behave as digital teammates, reduce the number of manual operations and maintain work consistency.\"},{\"q\":\"What do these agents do to support my team?\",\"a\":\"They take repetitive tasks, eliminate errors, and ensure things move without delays. That way, your team has more time for growth and work that really counts.\"},{\"q\":\"Do these agents replace people?\",\"a\":\"No, they do not work against human teams; they work with them. They manage routine jobs so staff can focus on higher goals.\"},{\"q\":\"Which businesses gain the most from ExactFlow?\",\"a\":\"Any e-commerce company – HR, finance, procurement or support – may benefit. It is best suited to businesses that intend to expand with less error and wasted time with workflow automation.\"},{\"q\":\"Why was ExactFlow created?\",\"a\":\"Our founder realized the potential of e-commerce businesses and the fact that they remained familiar with manual, disjointed work. ExactFlow was developed to clear these areas and introduce clarity, speed and trust to everyday work with ecommerce automation.\"}]}},\"contactUs\":{\"meta\":{\"title\":\"Contact ExactFlow | Get in Touch\",\"description\":\"Have questions or need support? Contact ExactFlow to connect with our team and get the help you need for smarter eCommerce operations.\"},\"hero\":{\"heading\":\"Contact Us\",\"title\":\"Let's work together\",\"subtext\":\"Any question or remark? Just write us a message\",\"bgAlt\":\"background illustration\"},\"address\":{\"heading\":\"Our Address\",\"value\":\"Stanisława Bodycha 87, 05-816 Reguły Poland\"},\"form\":{\"heading\":\"Share your ideas\",\"fullName\":\"Full name\",\"email\":\"Personal email address\",\"phone\":\"Phone number\",\"phonePlaceholder\":\"+1234567890\",\"message\":\"Message\",\"send\":\"Send Inquiry\",\"sendAria\":\"Send Inquiry\",\"sent\":\"✓ Sent Successfully\",\"workEmail\":\"Work email address\"},\"validation\":{\"nameRequired\":\"Name is required\",\"nameMin\":\"Name must be at least 2 characters long\",\"emailRequired\":\"Email is required\",\"emailInvalid\":\"Please enter a valid email address\",\"phoneRequired\":\"Phone number is required\",\"phoneInvalid\":\"Please enter a valid phone number\",\"messageRequired\":\"Message is required\",\"messageMin\":\"Message must be at least 2 characters long\"}},\"blogs\":{\"meta\":{\"title\":\"Blog | ExactFlow\",\"description\":\"Read the latest ExactFlow articles on eCommerce operations, customer support, CX, and AI agents — guides, strategies, and product updates.\"},\"list\":{\"heading\":\"Latest Blogs\",\"readMore\":\"Read More\",\"readMoreAriaPrefix\":\"Read more:\"},\"categories\":{\"all\":\"All\",\"Ecommerce\":\"Ecommerce\",\"Sales\":\"Sales\",\"Marketing\":\"Marketing\",\"Technology\":\"Technology\"},\"post\":{\"by\":\"By\",\"notFoundTitle\":\"Blog post not found.\"},\"posts\":{}}},\"children\":\"$L23\"}]}]}]}]}]\n"])</script><script>self.__next_f.push([1,"23:[\"$\",\"$L21\",null,{\"systemMode\":\"light\",\"children\":[\"$\",\"$L24\",null,{\"mode\":\"light\"}]}]\n"])</script><script>self.__next_f.push([1,"22:[\"$\",\"div\",null,{\"className\":\"ts-front-layout-root __className_1d85b0\",\"children\":[[\"$\",\"$L25\",null,{\"mode\":\"light\"}],[[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":